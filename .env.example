# Gemini API key — https://aistudio.google.com/apikey (free tier)
GOOGLE_API_KEY=

# Optional: Semantic Scholar API key raises the default rate limit.
# Works without one at a lower rate limit: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Postgres for session history. With Docker: docker compose up -d postgres
DATABASE_URL=postgresql://provenance:provenance@localhost:5432/provenance
